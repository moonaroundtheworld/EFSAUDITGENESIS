# ==========================================
# EFS Audit Genesis - Hostinger Production .ENV
# ==========================================

# Core Application Target
ENVIRONMENT=production
API_PORT=8000

# SQLite Genesis Vault Targeting (Relative paths normalized)
DATABASE_URL=sqlite:///genesis.db

# Encryption Arrays
# MUST be upgraded to a 256-bit randomized hash internally for Hostinger TLS
SECRET_KEY=your_256bit_secure_master_key_here

# Optional: PostgreSQL Override if migrating off SQLite
# POSTGRES_USER=efs_admin
# POSTGRES_PASSWORD=your_secure_password
# POSTGRES_DB=efs_genesis
# POSTGRES_HOST=127.0.0.1
